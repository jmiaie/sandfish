# SandFish configuration
# Copy this file to .env and edit the values, or export the variables in your shell.

# --- Memory backend ---------------------------------------------------------

# Path to the OMPA vault directory used for knowledge-graph and event storage.
# Created automatically if it does not exist.
OMPA_VAULT_PATH=./sandfish_vault

# --- API server -------------------------------------------------------------

# When set, all /api/* endpoints require an X-API-Key header that matches.
# Generate a strong value with: openssl rand -hex 32
# Leave unset to disable auth (development only).
SANDFISH_API_KEY=

# Sliding-window rate limit per (api_key | client IP). Default: 120.
SANDFISH_RATE_LIMIT_PER_MINUTE=120

# Comma-separated allowed origins for CORS. Empty disables credentialed CORS
# (browsers may still send simple cross-origin requests).
SANDFISH_CORS_ORIGINS=

# --- Optional integrations --------------------------------------------------

# If you wire an LLM-backed agent into your simulation, set its key here.
# Not used by the bundled agents.
LLM_API_KEY=
